{
  "name": "@zeldrisho/pi-zeldrova",
  "private": true,
  "description": "Monorepo for @zeldrisho Pi packages",
  "type": "module",
  "scripts": {
    "check": "vp check",
    "test": "vp test",
    "lint": "vp lint",
    "lint:fix": "vp lint --fix",
    "format": "vp fmt --write",
    "typecheck": "vp check --no-fmt --no-lint",
    "pack:dry-run": "for package in packages/*; do (cd \"$package\" && vp pm pack -- --dry-run) || exit; done",
    "prepare": "vp config"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.13.1"
}
